# DevForge Master Environment Configuration
# Copy this to .env and fill in your real production values

# --- Application ---
APP_NAME="DevForge Empire"
DEBUG=false
JWT_SECRET=generate-a-secure-random-string-here
ENCRYPTION_KEY=generate-a-fernet-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200

# --- URLs (Local Dev) ---
# For production, these are set in Vercel and Render.
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:3006

# --- Database ---
# Use a real PostgreSQL URL for production (Supabase/Neon/Railway)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/devforge

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Each product will have its own Price ID in Stripe
NEXT_PUBLIC_STRIPE_PRICE_ID_FILECLEANER=price_...
NEXT_PUBLIC_STRIPE_PRICE_ID_INVOICEFOLLOW=price_...
NEXT_PUBLIC_STRIPE_PRICE_ID_PRICETRACKR=price_...
NEXT_PUBLIC_STRIPE_PRICE_ID_WEBHOOKMONITOR=price_...
NEXT_PUBLIC_STRIPE_PRICE_ID_FEEDBACKLENS=price_...

# --- Polar (Payments) ---
# Leave POLAR_SERVER empty for production. Use "sandbox" with sandbox tokens/products.
POLAR_SERVER=
# Optional explicit override, e.g. https://sandbox-api.polar.sh/v1
POLAR_API_URL=
POLAR_ACCESS_TOKEN=polar_oat_...
POLAR_WEBHOOK_SECRET=whsec_...
POLAR_PRODUCT_ID_FILECLEANER=...
POLAR_PRODUCT_ID_INVOICEFOLLOW=...
POLAR_PRODUCT_ID_PRICETRACKR=...
POLAR_PRODUCT_ID_WEBHOOKMONITOR=...
POLAR_PRODUCT_ID_FEEDBACKLENS=...
POLAR_PRODUCT_ID_FILECLEANER_PRO=...
POLAR_PRODUCT_ID_INVOICEFOLLOW_PRO=...
POLAR_PRODUCT_ID_PRICETRACKR_PRO=...
POLAR_PRODUCT_ID_WEBHOOKMONITOR_PRO=...
POLAR_PRODUCT_ID_FEEDBACKLENS_PRO=...
POLAR_PRODUCT_ID_FILECLEANER_TEAM=...
POLAR_PRODUCT_ID_INVOICEFOLLOW_TEAM=...
POLAR_PRODUCT_ID_PRICETRACKR_TEAM=...
POLAR_PRODUCT_ID_WEBHOOKMONITOR_TEAM=...
POLAR_PRODUCT_ID_FEEDBACKLENS_TEAM=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_FILECLEANER=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_INVOICEFOLLOW=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_PRICETRACKR=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_WEBHOOKMONITOR=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_FEEDBACKLENS=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_FILECLEANER_PRO=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_INVOICEFOLLOW_PRO=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_PRICETRACKR_PRO=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_WEBHOOKMONITOR_PRO=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_FEEDBACKLENS_PRO=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_FILECLEANER_TEAM=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_INVOICEFOLLOW_TEAM=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_PRICETRACKR_TEAM=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_WEBHOOKMONITOR_TEAM=...
NEXT_PUBLIC_POLAR_PRODUCT_ID_FEEDBACKLENS_TEAM=...

# --- Email (SMTP - Resend/Postmark/SendGrid) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your-api-key
SMTP_FROM=noreply@yourdomain.com

# --- OAuth Redirects ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://devforge-universal-backend.onrender.com/connect/gmail/callback
FEEDBACKLENS_TWITTER_REDIRECT_URI=https://devforge-universal-backend.onrender.com/connect/twitter/callback
FEEDBACKLENS_REDDIT_REDIRECT_URI=https://devforge-universal-backend.onrender.com/connect/reddit/callback
FEEDBACKLENS_GITHUB_REDIRECT_URI=https://devforge-universal-backend.onrender.com/connect/github/callback

# --- FeedbackLens analysis ---
FEEDBACKLENS_ANALYSIS_ENGINE=local_transformers
FEEDBACKLENS_SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
FEEDBACKLENS_URGENCY_MODEL=cross-encoder/nli-deberta-v3-xsmall

# --- Storage (Cloudflare R2 / AWS S3 - for File Cleaner) ---
S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=devforge-uploads
S3_REGION=auto

# --- AI (Google Gemini - for Feedback Analyzer) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Operations ---
CRON_SECRET=your-render-and-cron-bearer-secret
CRONJOB_API_KEY=your-cron-job-org-api-key
RENDER_API_KEY=your-render-api-key

# --- Analytics (Plausible) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=devforge.io
